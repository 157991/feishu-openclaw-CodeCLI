{
  "name": "feishu-openclaw-CodeCLI",
  "version": "1.0.0",
  "description": "Trae 项目自动化 - 分析项目、管理飞书表格、调用 Cursor CLI",
  "type": "module",
  "main": "dist/index.js",
  "files": [
    "dist/index.js",
    "openclaw.plugin.json"
  ],
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ]
  },
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=node --format=esm --outfile=dist/index.js --external:openclaw",
    "dev": "esbuild src/index.ts --bundle --platform=node --format=esm --outfile=dist/index.js --external:openclaw --watch"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.7.0"
  }
}